# ==============================================================================
# FlowState Frontend Environment Variables Template
# Copy this file to '.env' and fill in your actual AWS resource identifiers.
# ==============================================================================

# ── AWS Cognito Configuration (Publicly Exposed to Client Browser) ────────────
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Backend WebSocket URL (For Real-time Sync & AI Sessions) ──────────────────
# Locally: ws://localhost:8080 or wss://your-backend-domain.com
NEXT_PUBLIC_BACKEND_WS_URL=ws://localhost:8080

# ── AWS IAM Credentials (Private: Only Read Server-Side in Route Handlers) ────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
